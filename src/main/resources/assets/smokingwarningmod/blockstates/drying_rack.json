{
  "multipart": [
    {
      "apply": {
        "model": "smokingwarningmod:block/drying_rack_empty"
      }
    },
    {
      "when": {
        "leaf_count": "1|2",
        "dried": "false"
      },
      "apply": {
        "model": "smokingwarningmod:block/drying_rack_leaves_fresh_sparse"
      }
    },
    {
      "when": {
        "leaf_count": "3|4",
        "dried": "false"
      },
      "apply": {
        "model": "smokingwarningmod:block/drying_rack_leaves_fresh_medium"
      }
    },
    {
      "when": {
        "leaf_count": "5",
        "dried": "false"
      },
      "apply": {
        "model": "smokingwarningmod:block/drying_rack_leaves_fresh_full"
      }
    },
    {
      "when": {
        "leaf_count": "1|2",
        "dried": "true"
      },
      "apply": {
        "model": "smokingwarningmod:block/drying_rack_leaves_dried_sparse"
      }
    },
    {
      "when": {
        "leaf_count": "3|4",
        "dried": "true"
      },
      "apply": {
        "model": "smokingwarningmod:block/drying_rack_leaves_dried_medium"
      }
    },
    {
      "when": {
        "leaf_count": "5",
        "dried": "true"
      },
      "apply": {
        "model": "smokingwarningmod:block/drying_rack_leaves_dried_full"
      }
    }
  ]
}
